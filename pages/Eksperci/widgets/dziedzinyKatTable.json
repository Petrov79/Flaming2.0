  "tableData": "{{\n(() => {\n\n  const typ = Number(RadioGroupWyszukaj.selectedOptionValue);\n  const wartosci = SelectWyszukaj.selectedOptionValues || [];\n\n  // Nic nie wybrano\n  if (wartosci.length === 0) {\n    return [];\n  }\n\n  // Dziedziny\n  if (typ === 1) {\n    return dziedzinyZKategoriami.data || [];\n  }\n\n  // Kategorie\n  if (typ === 2) {\n    return kategorieZDziedzinami.data || [];\n  }\n\n  return [];\n\n})()\n}}",
