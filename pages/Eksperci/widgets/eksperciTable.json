  "tableData": "{{\n(() => {\n\n  const typ = Number(RadioGroupWyszukaj.selectedOptionValue);\n  const wartosci = SelectWyszukaj.selectedOptionValues || [];\n\n  // Wykaz - zawsze pokazuj wszystkich ekspertów\n  if (typ === 0) {\n\n    const dane = eksperciWykaz.data || [];\n\n    return dane.map((row, index) => ({\n      lp: index + 1,\n      ...row\n    }));\n\n  }\n\n  // Dziedziny / Kategorie / Obszary\n  // Jeżeli nic nie wybrano - pusta tabela\n  if (wartosci.length === 0) {\n    return [];\n  }\n\n  let dane = [];\n\n  if (typ === 1) {\n    dane = eksperciDziedziny.data || [];\n  } else if (typ === 2) {\n    dane = eksperciKategorie.data || [];\n  } else if (typ === 3) {\n    dane = eksperciObszary.data || [];\n  }\n\n  return dane.map((row, index) => ({\n    lp: index + 1,\n    ...row\n  }));\n\n})()\n}}",
